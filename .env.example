# Copy to .env for local development. All variables are optional —
# defaults work out of the box for local runs.

# Discord webhook for run summaries (CI) and per-job alerts (watch mode).
# Leave empty to disable notifications.
DISCORD_WEBHOOK_URL=

# Where state files live (job_ids.json, jobs.db, jobs.json).
# CI points this at the data repo checkout; locally the default is fine.
#DATA_DIR=local_data

# Where the public intern/SWE tables are written.
#README_PATH=README.md

# Where the target-companies feed is written.
#TARGET_README_PATH=README.md

# Watchlist location.
#TARGET_COMPANIES_FILE=local_data/target_companies.json
